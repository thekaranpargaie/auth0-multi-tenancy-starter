# ── Auth0 SPA Configuration (required) ──────────────────────────────────────
# All VITE_ variables are baked into the build at build time.
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your_spa_client_id
VITE_AUTH0_AUDIENCE=https://your-tenant.us.auth0.com/api/v2/

# ── Backend API URL (required) ───────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000

# ── Google OAuth Configuration ───────────────────────────────────────────────
# Get these from Google Cloud Console
# https://console.cloud.google.com/ -> APIs & Services -> Credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id

# ── Microsoft OAuth Configuration ───────────────────────────────────────────
# Get these from Azure Portal
# https://portal.azure.com/ -> Azure Active Directory -> App registrations
VITE_MICROSOFT_CLIENT_ID=your_microsoft_client_id
VITE_MICROSOFT_TENANT_ID=your_microsoft_tenant_id
