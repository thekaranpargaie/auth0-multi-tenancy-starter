# ╔══════════════════════════════════════════════════════════════════════════╗
# ║             Auth0 Multi-Tenant SaaS — Root Environment File            ║
# ║  Copy this file to .env and fill in real values before running Docker. ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── Auth0 (required) ─────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_AUDIENCE=https://your-tenant.us.auth0.com/api/v2/

# SPA Application (frontend)
AUTH0_APP_CLIENT_ID=your_spa_client_id_here

# Test Applications for SSO demonstration
VITE_CRM_CLIENT_ID=your_crm_client_id_here
VITE_NOTES_CLIENT_ID=your_notes_client_id_here

# Machine-to-Machine Application (backend → Auth0 Management API)
AUTH0_M2M_CLIENT_ID=your_m2m_client_id_here
AUTH0_M2M_CLIENT_SECRET=your_m2m_client_secret_here

# Organization Roles (format: rol_xxxxxxxxxxxxxxxx)
AUTH0_ADMIN_ROLE_ID=rol_xxxxxxxxxxxxxxxx
AUTH0_MEMBER_ROLE_ID=rol_yyyyyyyyyyyyyyyy

# Auth0 database connection name (usually unchanged)
AUTH0_CONNECTION=Username-Password-Authentication

# ── Google OAuth (Frontend) ──────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/ -> APIs & Services -> Credentials
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# ── Microsoft OAuth (Frontend & Backend) ─────────────────────────────────────
# Get from: https://portal.azure.com/ -> Azure AD -> App registrations
VITE_MICROSOFT_CLIENT_ID=your_microsoft_client_id_here
VITE_MICROSOFT_TENANT_ID=your_microsoft_tenant_id_here
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_here

# ── Test Applications (SSO demo) ─────────────────────────────────────────────
# These are for the CRM (Vue 3) and Notes (React) test applications
# Create separate Single Page Applications in Auth0 for each
VITE_CRM_CLIENT_ID=your_crm_client_id_here    # CRM App Auth0 Client ID
VITE_NOTES_CLIENT_ID=your_notes_client_id_here  # Notes App Auth0 Client ID

# ── Application URLs (required) ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000

# ── SMTP Email (optional — app works without it) ─────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SMTP_FROM_EMAIL=noreply@yourcompany.com
SMTP_FROM_NAME=YourCompany
SMTP_USE_TLS=true