# ── Auth0 Configuration (required) ──────────────────────────────────────────
Auth0__Domain=your-tenant.us.auth0.com
Auth0__Audience=https://your-tenant.us.auth0.com/api/v2/
Auth0__M2MClientId=your_m2m_client_id
Auth0__M2MClientSecret=your_m2m_client_secret
Auth0__AppClientId=your_spa_client_id
Auth0__AdminRoleId=rol_xxxxxxxxxxxxxxxx
Auth0__MemberRoleId=rol_yyyyyyyyyyyyyyyy
Auth0__Connection=Username-Password-Authentication

# ── Application (required) ───────────────────────────────────────────────────
App__FrontendUrl=http://localhost:5173

# ── SMTP Email (optional) ────────────────────────────────────────────────────
Smtp__Server=smtp.gmail.com
Smtp__Port=587
Smtp__Username=your-email@gmail.com
Smtp__Password=your-app-specific-password
Smtp__FromEmail=noreply@yourcompany.com
Smtp__FromName=YourApp
Smtp__UseTls=true

# ── ASP.NET Core ─────────────────────────────────────────────────────────────
ASPNETCORE_ENVIRONMENT=Production
ASPNETCORE_URLS=http://+:8000
